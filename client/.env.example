# FSCM Client - Environment Variables

# The base URL for the API. 
# Local: Leave empty or set to /api
# Production: https://your-backend.up.railway.app/api
VITE_API_BASE_URL=

# Socket.io connection URL
# Local: Leave empty
# Production: https://your-backend.up.railway.app
VITE_SOCKET_URL=

# Uploads URL (Optional, defaults to backend_url/uploads)
# Production: https://your-backend.up.railway.app/uploads
VITE_UPLOADS_URL=
