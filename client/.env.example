# FSCM Client - Environment Variables

# The base URL for the API. In development, this is usually empty (proxied via Vite).
# In production, if the frontend and backend are on different domains, set this to the backend URL.
# If using the monolith approach (backend serves frontend), keep it empty or set to '/api'.
VITE_API_BASE_URL=

# Socket.io connection URL
VITE_SOCKET_URL=
